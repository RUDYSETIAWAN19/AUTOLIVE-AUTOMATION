{
  "name": "autolive-mobile",
  "version": "1.0.0",
  "description": "AutoLive Automation Mobile App",
  "main": "index.js",
  "scripts": {
    "build": "cd ../frontend && npm run build",
    "sync": "npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "build:android": "npm run build && npm run sync && npx cap copy android && cd android && ./gradlew assembleDebug",
    "build:release": "npm run build && npm run sync && npx cap copy android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/app": "^5.0.0",
    "@capacitor/camera": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/filesystem": "^5.0.0",
    "@capacitor/haptics": "^5.0.0",
    "@capacitor/keyboard": "^5.0.0",
    "@capacitor/push-notifications": "^5.0.0",
    "@capacitor/status-bar": "^5.0.0",
    "@capacitor/storage": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0"
  }
}
