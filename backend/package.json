{
  "name": "autolive-backend",
  "version": "1.0.0",
  "description": "AutoLive Automation Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "type-check:report": "tsc --noEmit --pretty false > typescript-report.txt 2>&1 || true"
  },
  "dependencies": {
